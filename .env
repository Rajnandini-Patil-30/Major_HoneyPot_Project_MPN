# Database Configuration
DB_TYPE=sqlite                          # sqlite or postgresql
DB_PATH=./honeypot.db                   # For SQLite
DB_HOST=localhost                       # For PostgreSQL
DB_PORT=5432                            # For PostgreSQL
DB_NAME=honeypot_db                     # For PostgreSQL
DB_USER=honeypot_user                   # For PostgreSQL
DB_PASSWORD=change_me_in_production     # For PostgreSQL

# Service Configuration
SSH_PORT=2222
HTTP_PORT=8080
FTP_PORT=2121
TELNET_PORT=2323
SMTP_PORT=2525

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change_this_secret_key_in_production

# Geolocation Configuration
GEO_API_KEY=                            # Optional: ip-api.com key
GEO_OFFLINE_DB=./geo_service/GeoLite2-City.mmdb
USE_OFFLINE_GEO=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/honeypot.log
RETENTION_DAYS=90

# Dashboard Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123                 # Change in production

# Docker Configuration
DOCKER_NETWORK=honeypot_network
